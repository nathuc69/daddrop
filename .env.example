# DadDrop — variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs (Supabase → Project Settings → API).
# Sur Vercel : ajoute ces mêmes clés dans Project Settings → Environment Variables.

# URL publique du projet Supabase (ex: https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clé anon (publique) — Supabase → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service_role (SECRÈTE, serveur uniquement) — ne jamais exposer côté client
SUPABASE_SERVICE_ROLE_KEY=

# URL de base du site, utilisée pour générer les liens de cartes.
# En local: http://localhost:3000 — en prod: https://ton-projet.vercel.app
NEXT_PUBLIC_BASE_URL=
